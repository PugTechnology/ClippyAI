# GitHub Webhook Secret for validating incoming payloads
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub Personal Access Token (PAT) for the machine user (e.g., google-jules)
GITHUB_PAT=your_github_pat_here

# Gemini API Key for the Analyst and Reviewer agents
GEMINI_API_KEY=your_gemini_api_key_here

# The owner of the repository where HiveMind operates
REPO_OWNER=your_github_username

# The name of the repository where HiveMind operates
REPO_NAME=your_repo_name
